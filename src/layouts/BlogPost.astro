---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import EditorialImage from '../components/EditorialImage.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_AUTHOR, SITE_TITLE, SITE_URL } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, deck, pubDate, updatedDate, category, tags, author, heroImage } = Astro.props;
const canonical = new URL(Astro.url.pathname, SITE_URL).toString();
const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description,
	author: {
		'@type': 'Organization',
		name: author ?? SITE_AUTHOR,
	},
	publisher: {
		'@type': 'Organization',
		name: SITE_TITLE,
	},
	datePublished: pubDate.toISOString(),
	dateModified: (updatedDate ?? pubDate).toISOString(),
	mainEntityOfPage: canonical,
};
---

<html lang="en">
	<head>
		<BaseHead
			title={`${title} | ${SITE_TITLE}`}
			description={description}
			canonical={canonical}
			ogType="article"
			publishedTime={pubDate.toISOString()}
			modifiedTime={(updatedDate ?? pubDate).toISOString()}
			structuredData={structuredData}
		/>
		<style>
			.article-shell {
				width: min(1200px, calc(100% - 2rem));
				margin: 0 auto;
				padding: 3rem 0 5rem;
			}

			.story-grid {
				display: grid;
				grid-template-columns: minmax(0, 210px) minmax(0, 1fr);
				gap: 2rem;
				align-items: start;
			}

			.story-meta {
				position: sticky;
				top: 6rem;
				padding: 1.25rem;
				border: 1px solid rgba(var(--ink), 0.08);
				border-radius: 1.5rem;
				background: rgba(255, 255, 255, 0.56);
			}

			.story-meta p,
			.story-meta ul {
				margin: 0.45rem 0 0;
			}

			.story-meta h2 {
				font-size: 0.85rem;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				margin-top: 0;
			}

			.story-meta ul {
				padding-left: 1rem;
			}

			.story {
				max-width: 760px;
			}

			.hero-visual {
				margin: 0 0 1.5rem;
			}

			.kicker {
				display: inline-flex;
				padding: 0.4rem 0.8rem;
				border-radius: 999px;
				background: rgba(255, 107, 44, 0.12);
				color: var(--signal-deep);
				font-size: 0.76rem;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}

			.story header {
				padding-bottom: 1.5rem;
				margin-bottom: 1.75rem;
				border-bottom: 1px solid rgba(var(--ink), 0.1);
			}

			.story h1 {
				font-size: clamp(2.6rem, 5vw, 4.8rem);
				line-height: 0.96;
				margin: 1rem 0 0.75rem;
			}

			.deck {
				font-size: 1.2rem;
				color: rgba(var(--ink), 0.76);
				max-width: 48rem;
			}

			.story-dates {
				display: flex;
				flex-wrap: wrap;
				gap: 1rem;
				color: rgba(var(--ink), 0.64);
				font-size: 0.95rem;
			}

			.prose {
				font-size: 1.08rem;
			}

			.prose h2,
			.prose h3 {
				scroll-margin-top: 6rem;
			}

			.prose table {
				border-collapse: collapse;
			}

			.prose th,
			.prose td {
				padding: 0.8rem;
				border: 1px solid rgba(var(--ink), 0.12);
			}

			@media (max-width: 900px) {
				.story-grid {
					grid-template-columns: 1fr;
				}

				.story-meta {
					position: static;
					order: 2;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main class="article-shell">
			<article class="story-grid">
				<aside class="story-meta" aria-label="Article details">
					<h2>Filed Under</h2>
					<p>{category}</p>
					<h2>Published</h2>
					<p><FormattedDate date={pubDate} /></p>
					{
						updatedDate && (
							<>
								<h2>Updated</h2>
								<p><FormattedDate date={updatedDate} /></p>
							</>
						)
					}
					<h2>Byline</h2>
					<p>{author ?? SITE_AUTHOR}</p>
					<h2>Tags</h2>
					<ul>
						{tags.map((tag) => <li>{tag}</li>)}
					</ul>
				</aside>
				<div class="story">
					<header>
						<p class="kicker">{category}</p>
						<h1>{title}</h1>
						<p class="deck">{deck}</p>
						<div class="story-dates">
							<span>Published <FormattedDate date={pubDate} /></span>
							{updatedDate && <span>Updated <FormattedDate date={updatedDate} /></span>}
						</div>
					</header>
					<EditorialImage image={heroImage} className="hero-visual" loading="eager" />
					<div class="prose">
						<slot />
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
