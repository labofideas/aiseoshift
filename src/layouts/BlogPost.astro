---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import EditorialImage from '../components/EditorialImage.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_AUTHOR, SITE_TITLE, SITE_URL } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & {
	headings?: Array<{ depth: number; slug: string; text: string }>;
	relatedPosts?: CollectionEntry<'blog'>[];
	imageManifest?: Record<string, any>;
};

const {
	title, description, deck, pubDate, updatedDate, category, tags, author,
	heroImage, headings = [], relatedPosts = [], imageManifest = {},
} = Astro.props;

const canonical = new URL(Astro.url.pathname, SITE_URL).toString();
const readTime = Math.max(3, Math.round((description.length + deck.length + title.length + tags.join(' ').length * 30) / 180));
const tocHeadings = headings.filter((h) => h.depth <= 3 && h.text !== 'Related reading' && h.text !== 'References');
const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description,
	author: { '@type': 'Organization', name: author ?? SITE_AUTHOR },
	publisher: { '@type': 'Organization', name: SITE_TITLE },
	datePublished: pubDate.toISOString(),
	dateModified: (updatedDate ?? pubDate).toISOString(),
	mainEntityOfPage: canonical,
};
---

<html lang="en">
	<head>
		<BaseHead
			title={`${title} | ${SITE_TITLE}`}
			description={description}
			canonical={canonical}
			ogType="article"
			publishedTime={pubDate.toISOString()}
			modifiedTime={(updatedDate ?? pubDate).toISOString()}
			structuredData={structuredData}
		/>
		<style>
			.article-shell {
				width: min(1240px, calc(100% - 2rem));
				margin: 0 auto;
				padding: 1.6rem 0 3rem;
				overflow-x: hidden;
			}

			.story-grid {
				display: grid;
				grid-template-columns: minmax(0, 220px) minmax(0, 1fr);
				gap: 2rem;
				align-items: start;
			}

			/* ── Sidebar / TOC ── */
			.story-sidebar {
				position: sticky;
				top: 5rem;
				padding: 0.5rem 1.2rem 1rem 0;
				border-right: 1px solid var(--line);
				max-height: calc(100vh - 6rem);
				overflow-y: auto;
			}

			.toc-nav { margin-bottom: 1.5rem; }

			.toc-title,
			.meta-title {
				font-size: 0.68rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.14em;
				color: rgba(var(--ink), 0.42);
				margin: 0 0 0.6rem;
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
			}

			.toc-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}

			.toc-item { margin: 0; }
			.toc-h3 { padding-left: 0.75rem; }

			.toc-link {
				display: block;
				padding: 0.28rem 0 0.28rem 0.6rem;
				font-size: 0.78rem;
				line-height: 1.35;
				color: rgba(var(--ink), 0.52);
				text-decoration: none;
				border-left: 2px solid transparent;
				transition: color 140ms ease, border-color 140ms ease;
			}

			.toc-link:hover { color: rgb(var(--ink)); }

			.toc-link.active {
				color: var(--signal-deep);
				border-left-color: var(--signal);
				font-weight: 700;
			}

			.meta-block {
				padding-top: 1rem;
				border-top: 1px solid var(--line);
			}

			.meta-block p {
				margin: 0.2rem 0 0;
				font-size: 0.82rem;
				color: rgba(var(--ink), 0.68);
			}

			.meta-block ul {
				padding: 0;
				margin: 0.3rem 0 0;
				list-style: none;
			}

			.meta-block li {
				font-size: 0.78rem;
				color: rgba(var(--ink), 0.62);
				padding: 0.15rem 0;
			}

			.meta-title + p,
			.meta-title + ul { margin-top: 0; }

			.meta-block + .meta-block { margin-top: 0.9rem; }

			/* ── Story Content ── */
			.story { max-width: 820px; }

			.story-header { margin-bottom: 1.75rem; }

			.breadcrumbs {
				margin: 0 0 1rem;
				font-size: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 0.12em;
				color: rgba(var(--ink), 0.48);
			}

			.breadcrumbs a {
				text-decoration: none;
				color: inherit;
			}

			.breadcrumbs a:hover { color: var(--signal-deep); }

			.hero-visual { margin: 0 0 1.4rem; }

			.kicker {
				display: inline-flex;
				padding: 0.35rem 0.7rem;
				border-bottom: 1px solid rgba(217, 106, 58, 0.25);
				color: var(--signal-deep);
				font-size: 0.68rem;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}

			.story h1 {
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
				font-size: clamp(2rem, 3.8vw, 3rem);
				line-height: 1.06;
				letter-spacing: -0.025em;
				margin: 0.85rem 0 0.9rem;
				max-width: 18ch;
			}

			.deck {
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
				font-size: 1.02rem;
				line-height: 1.65;
				color: rgba(var(--ink), 0.7);
				max-width: 46rem;
				margin: 0 0 1rem;
			}

			.story-dates {
				display: flex;
				flex-wrap: wrap;
				gap: 1rem;
				color: rgba(var(--ink), 0.58);
				font-size: 0.82rem;
				padding-bottom: 1rem;
				border-bottom: 1px solid var(--line);
			}

			/* ── Prose Typography ── */
			/* Use :global() for child selectors because slotted MDX content
			   does not receive Astro's scoped data-astro-cid attribute. */
			.prose {
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
				font-size: 1rem;
				line-height: 1.78;
				letter-spacing: -0.003em;
				max-width: 70ch;
			}

			.prose > :global(p:first-of-type) {
				font-size: 1.06rem;
				line-height: 1.78;
				color: rgba(var(--ink), 0.88);
			}

			.prose :global(h2) {
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
				font-size: clamp(1.45rem, 1.8vw, 1.9rem);
				line-height: 1.22;
				letter-spacing: -0.02em;
				margin-top: 3.2rem;
				margin-bottom: 0.9rem;
				padding-top: 1.2rem;
				border-top: 1px solid var(--line);
			}

			.prose :global(h2:first-child) {
				border-top: none;
				padding-top: 0;
			}

			.prose :global(h3) {
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
				font-size: 1.14rem;
				line-height: 1.35;
				letter-spacing: -0.01em;
				margin-top: 2.2rem;
				margin-bottom: 0.6rem;
			}

			.prose :global(h2), .prose :global(h3) { scroll-margin-top: 6rem; }

			.prose :global(table) {
				border-collapse: collapse;
				margin: 1.8rem 0;
				font-size: 0.94rem;
				display: block;
				overflow-x: auto;
				-webkit-overflow-scrolling: touch;
			}

			.prose :global(th),
			.prose :global(td) {
				padding: 0.75rem 0.85rem;
				border: 1px solid rgba(var(--ink), 0.1);
			}

			.prose :global(th) {
				background: rgba(var(--ink), 0.04);
				font-weight: 700;
				text-align: left;
			}

			.prose :global(ul), .prose :global(ol) {
				padding-left: 1.1rem;
				margin: 1rem 0 1.4rem;
			}

			.prose :global(li) {
				padding-left: 0.2rem;
				margin-top: 0.45rem;
			}

			.prose :global(p), .prose :global(ul), .prose :global(ol), .prose :global(table), .prose :global(blockquote) {
				margin-bottom: 1.4rem;
			}

			.prose :global(blockquote) {
				font-size: 1rem;
				line-height: 1.75;
				margin: 2rem 0;
			}

			.prose :global(ul + h2), .prose :global(ol + h2), .prose :global(table + h2),
			.prose :global(ul + h3), .prose :global(ol + h3), .prose :global(table + h3) {
				margin-top: 3.2rem;
			}

			.prose :global(hr) {
				margin: 3rem 0;
				border: none;
				border-top: 1px solid var(--line);
			}

			.prose :global(img) { border-radius: 10px; }

			.prose :global(pre) {
				max-width: 100%;
			}

			/* ── Related Posts ── */
			.related-section {
				width: min(1240px, calc(100% - 2rem));
				margin: 0 auto;
				padding: 2.5rem 0 3rem;
				border-top: 1px solid var(--line);
			}

			.related-heading {
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
				font-size: 1.3rem;
				letter-spacing: -0.015em;
				margin: 0 0 1.2rem;
			}

			.related-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.25rem;
			}

			.related-card {
				text-decoration: none;
				color: inherit;
				padding: 1.15rem;
				border: 1px solid var(--line);
				border-radius: 1.15rem;
				background: rgba(var(--paper-strong), 0.5);
				transition: transform 140ms ease, box-shadow 140ms ease;
				display: block;
			}

			.related-card:hover {
				transform: translateY(-3px);
				box-shadow: 0 8px 24px rgba(var(--ink), 0.08);
			}

			.related-thumb {
				width: 100%;
				aspect-ratio: 16 / 9;
				object-fit: cover;
				border-radius: 0.7rem;
				margin-bottom: 0.7rem;
			}

			.related-cat {
				font-size: 0.66rem;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				font-weight: 700;
				color: var(--signal-deep);
			}

			.related-title {
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
				font-size: 1.05rem;
				line-height: 1.28;
				margin: 0.35rem 0 0;
				font-weight: 700;
			}

			/* ── Responsive ── */
			@media (max-width: 900px) {
				.story-grid {
					grid-template-columns: 1fr;
				}

				.story-sidebar {
					position: static;
					order: -1;
					border-right: 0;
					padding-right: 0;
					max-height: none;
					border-bottom: 1px solid var(--line);
					padding-bottom: 1rem;
					margin-bottom: 0.5rem;
				}

				.meta-block { display: none; }

				.toc-list {
					display: flex;
					flex-wrap: wrap;
					gap: 0.3rem 0.8rem;
				}

				.toc-h3 { display: none; }

				.toc-link {
					border-left: none;
					padding-left: 0;
					font-size: 0.74rem;
				}

				.story h1 { max-width: none; }
				.prose { max-width: none; }

				.related-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main class="article-shell">
			<article class="story-grid">
				<aside class="story-sidebar" aria-label="Table of contents">
					{tocHeadings.length > 0 && (
						<nav class="toc-nav" aria-label="Table of contents">
							<p class="toc-title">In This Article</p>
							<ul class="toc-list">
								{tocHeadings.map((h) => (
									<li class:list={['toc-item', { 'toc-h3': h.depth === 3 }]}>
										<a href={`#${h.slug}`} class="toc-link">{h.text}</a>
									</li>
								))}
							</ul>
						</nav>
					)}
					<div class="meta-block">
						<p class="meta-title">Category</p>
						<p>{category}</p>
					</div>
					<div class="meta-block">
						<p class="meta-title">Published</p>
						<p><FormattedDate date={pubDate} /></p>
					</div>
					{updatedDate && (
						<div class="meta-block">
							<p class="meta-title">Updated</p>
							<p><FormattedDate date={updatedDate} /></p>
						</div>
					)}
					<div class="meta-block">
						<p class="meta-title">Read Time</p>
						<p>{readTime} min</p>
					</div>
					<div class="meta-block">
						<p class="meta-title">Tags</p>
						<ul>
							{tags.map((tag) => <li>{tag}</li>)}
						</ul>
					</div>
				</aside>
				<div class="story">
					<header class="story-header">
						<p class="breadcrumbs"><a href="/">Home</a> / <a href="/blog">Latest</a> / {category}</p>
						<p class="kicker">{category}</p>
						<h1>{title}</h1>
						<p class="deck">{deck}</p>
						<div class="story-dates">
							<span>Published <FormattedDate date={pubDate} /></span>
							{updatedDate && <span>Updated <FormattedDate date={updatedDate} /></span>}
						</div>
					</header>
					<EditorialImage image={heroImage} className="hero-visual" loading="eager" />
					<div class="prose">
						<slot />
					</div>
				</div>
			</article>
		</main>

		{relatedPosts.length > 0 && (
			<section class="related-section" aria-label="Related articles">
				<h2 class="related-heading">Continue Reading</h2>
				<div class="related-grid">
					{relatedPosts.map((rp) => (
						<a href={`/blog/${rp.id}/`} class="related-card">
							{imageManifest[rp.id as keyof typeof imageManifest]?.hero && (
								<img
									class="related-thumb"
									src={(imageManifest[rp.id as keyof typeof imageManifest] as any).hero.src}
									alt={(imageManifest[rp.id as keyof typeof imageManifest] as any).hero.alt}
									loading="lazy"
								/>
							)}
							<span class="related-cat">{rp.data.category}</span>
							<h3 class="related-title">{rp.data.title}</h3>
						</a>
					))}
				</div>
			</section>
		)}

		<Footer />

		<script>
			function initToc() {
				const links = document.querySelectorAll('.toc-link');
				if (!links.length) return;

				const ids = Array.from(links).map((l) => l.getAttribute('href')?.slice(1)).filter(Boolean) as string[];
				const targets = ids.map((id) => document.getElementById(id)).filter(Boolean) as HTMLElement[];

				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								links.forEach((l) => l.classList.remove('active'));
								const active = document.querySelector(`.toc-link[href="#${entry.target.id}"]`);
								if (active) active.classList.add('active');
							}
						});
					},
					{ rootMargin: '-80px 0px -66% 0px', threshold: 0 }
				);

				targets.forEach((t) => observer.observe(t));
			}
			initToc();
		</script>
	</body>
</html>
