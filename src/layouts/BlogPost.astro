---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import EditorialImage from '../components/EditorialImage.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_AUTHOR, SITE_TITLE, SITE_URL } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, deck, pubDate, updatedDate, category, tags, author, heroImage } = Astro.props;
const canonical = new URL(Astro.url.pathname, SITE_URL).toString();
const readTime = Math.max(3, Math.round((description.length + deck.length + title.length + tags.join(' ').length * 30) / 180));
const structuredData = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description,
	author: {
		'@type': 'Organization',
		name: author ?? SITE_AUTHOR,
	},
	publisher: {
		'@type': 'Organization',
		name: SITE_TITLE,
	},
	datePublished: pubDate.toISOString(),
	dateModified: (updatedDate ?? pubDate).toISOString(),
	mainEntityOfPage: canonical,
};
---

<html lang="en">
	<head>
		<BaseHead
			title={`${title} | ${SITE_TITLE}`}
			description={description}
			canonical={canonical}
			ogType="article"
			publishedTime={pubDate.toISOString()}
			modifiedTime={(updatedDate ?? pubDate).toISOString()}
			structuredData={structuredData}
		/>
		<style>
			.article-shell {
				width: min(1240px, calc(100% - 2rem));
				margin: 0 auto;
				padding: 1.6rem 0 5rem;
			}

			.story-grid {
				display: grid;
				grid-template-columns: minmax(0, 220px) minmax(0, 1fr);
				gap: 2rem;
				align-items: start;
			}

			.story-meta {
				position: sticky;
				top: 6rem;
				padding: 1rem 0 0;
				border-right: 1px solid var(--line);
				padding-right: 1.2rem;
			}

			.story-meta p,
			.story-meta ul {
				margin: 0.35rem 0 0;
			}

			.story-meta h2 {
				font-size: 0.72rem;
				text-transform: uppercase;
				letter-spacing: 0.14em;
				margin: 1.1rem 0 0;
				color: rgba(var(--ink), 0.46);
			}

			.story-meta h2:first-child {
				margin-top: 0;
			}

			.story-meta ul {
				padding-left: 0;
				list-style: none;
			}

			.story-meta li {
				margin-top: 0.45rem;
				padding: 0.2rem 0;
				border-bottom: 1px dotted rgba(var(--ink), 0.1);
			}

			.story {
				max-width: 820px;
			}

			.story-header {
				margin-bottom: 1.75rem;
			}

			.breadcrumbs {
				margin: 0 0 1rem;
				font-size: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 0.12em;
				color: rgba(var(--ink), 0.52);
			}

			.breadcrumbs a {
				text-decoration: none;
				color: inherit;
			}

			.hero-visual {
				margin: 0 0 1.4rem;
			}

			.kicker {
				display: inline-flex;
				padding: 0.4rem 0.8rem;
				border-radius: 0;
				background: transparent;
				border-bottom: 1px solid rgba(217, 106, 58, 0.25);
				color: var(--signal-deep);
				font-size: 0.68rem;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}

			.story h1 {
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
				font-size: clamp(2.2rem, 4.1vw, 3.4rem);
				line-height: 1.02;
				letter-spacing: -0.03em;
				margin: 0.85rem 0 0.9rem;
				max-width: 13ch;
			}

			.deck {
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
				font-size: 1.02rem;
				line-height: 1.65;
				color: rgba(var(--ink), 0.72);
				max-width: 46rem;
				margin: 0 0 1rem;
			}

			.story-dates {
				display: flex;
				flex-wrap: wrap;
				gap: 1rem;
				color: rgba(var(--ink), 0.64);
				font-size: 0.82rem;
				padding-bottom: 1rem;
				border-bottom: 1px solid var(--line);
			}

			.prose {
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
				font-size: 1rem;
				line-height: 1.78;
				letter-spacing: -0.003em;
				max-width: 70ch;
			}

			.prose > p:first-of-type {
				font-size: 1.06rem;
				line-height: 1.78;
				color: rgba(var(--ink), 0.88);
			}

			.prose h2 {
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
				font-size: clamp(1.45rem, 1.8vw, 1.9rem);
				line-height: 1.22;
				letter-spacing: -0.02em;
				margin-top: 2.8rem;
				margin-bottom: 0.9rem;
			}

			.prose h3 {
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
				font-size: 1.14rem;
				line-height: 1.35;
				letter-spacing: -0.01em;
				margin-top: 1.8rem;
				margin-bottom: 0.6rem;
			}

			.prose h2,
			.prose h3 {
				scroll-margin-top: 6rem;
			}

			.prose table {
				border-collapse: collapse;
				margin: 1.6rem 0;
				font-size: 0.94rem;
			}

			.prose th,
			.prose td {
				padding: 0.8rem;
				border: 1px solid rgba(var(--ink), 0.12);
			}

			.prose ul,
			.prose ol {
				padding-left: 1.1rem;
				margin: 1rem 0 1.35rem;
			}

			.prose li {
				padding-left: 0.2rem;
				margin-top: 0.45rem;
			}

			.prose p,
			.prose ul,
			.prose ol,
			.prose table,
			.prose blockquote {
				margin-bottom: 1.35rem;
			}

			.prose blockquote {
				font-size: 1rem;
				line-height: 1.75;
			}

			@media (max-width: 900px) {
				.story-grid {
					grid-template-columns: 1fr;
				}

				.story-meta {
					position: static;
					order: 2;
					padding-top: 1rem;
					border-top: 1px solid var(--line);
					border-right: 0;
					padding-right: 0;
					display: grid;
					grid-template-columns: repeat(2, minmax(0, 1fr));
					column-gap: 1.25rem;
				}

				.story h1 {
					max-width: none;
				}

				.prose {
					max-width: none;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main class="article-shell">
			<article class="story-grid">
				<aside class="story-meta" aria-label="Article details">
					<h2>Filed Under</h2>
					<p>{category}</p>
					<h2>Published</h2>
					<p><FormattedDate date={pubDate} /></p>
					{
						updatedDate && (
							<>
								<h2>Updated</h2>
								<p><FormattedDate date={updatedDate} /></p>
							</>
						)
					}
					<h2>Byline</h2>
					<p>{author ?? SITE_AUTHOR}</p>
					<h2>Read Time</h2>
					<p>{readTime} min read</p>
					<h2>Tags</h2>
					<ul>
						{tags.map((tag) => <li>{tag}</li>)}
					</ul>
				</aside>
				<div class="story">
					<header class="story-header">
						<p class="breadcrumbs"><a href="/">Home</a> / <a href="/blog">Latest</a> / {category}</p>
						<p class="kicker">{category}</p>
						<h1>{title}</h1>
						<p class="deck">{deck}</p>
						<div class="story-dates">
							<span>Published <FormattedDate date={pubDate} /></span>
							{updatedDate && <span>Updated <FormattedDate date={updatedDate} /></span>}
						</div>
					</header>
					<EditorialImage image={heroImage} className="hero-visual" loading="eager" />
					<div class="prose">
						<slot />
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
