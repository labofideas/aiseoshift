---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description="AISEOShift covers AI visibility, answer engine optimization, and the editorial systems SEO teams need in the AI search era." />
		<style>
			.about-page {
				width: min(1000px, calc(100% - 2rem));
				margin: 0 auto;
				padding: 2.5rem 0 4rem;
			}

			.about-hero {
				margin-bottom: 2.5rem;
				padding-bottom: 2rem;
				border-bottom: 1px solid var(--line);
			}

			.about-hero h1 {
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
				font-size: clamp(2rem, 3.5vw, 2.8rem);
				line-height: 1.1;
				letter-spacing: -0.025em;
				margin: 0.5rem 0 1rem;
				max-width: 20ch;
			}

			.about-hero p {
				font-size: 1.05rem;
				line-height: 1.72;
				color: rgba(var(--ink), 0.8);
				max-width: 38rem;
			}

			.about-grid {
				display: grid;
				grid-template-columns: minmax(0, 1.2fr) minmax(260px, 0.8fr);
				gap: 1.5rem;
				margin-bottom: 2.5rem;
			}

			.about-card {
				padding: 1.75rem;
				border-radius: 1.5rem;
				border: 1px solid var(--line);
				background: rgba(var(--paper-strong), 0.55);
			}

			.about-card h2 {
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
				font-size: 1.25rem;
				margin: 0 0 0.8rem;
				letter-spacing: -0.01em;
			}

			.about-card p {
				font-size: 0.94rem;
				line-height: 1.7;
				color: rgba(var(--ink), 0.78);
			}

			.about-card ul {
				padding-left: 1.1rem;
				margin: 0.5rem 0 0;
			}

			.about-card li {
				font-size: 0.92rem;
				line-height: 1.6;
				color: rgba(var(--ink), 0.78);
				padding: 0.3rem 0;
			}

			.about-card li + li {
				border-top: 1px solid var(--line);
			}

			.about-values {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.25rem;
			}

			.value-card {
				padding: 1.5rem;
				border-radius: 1.25rem;
				border: 1px solid var(--line);
				background: rgba(var(--paper-strong), 0.55);
			}

			.value-card h3 {
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
				font-size: 1.05rem;
				margin: 0 0 0.5rem;
			}

			.value-card p {
				font-size: 0.86rem;
				line-height: 1.6;
				color: rgba(var(--ink), 0.7);
				margin: 0;
			}

			@media (max-width: 860px) {
				.about-grid {
					grid-template-columns: 1fr;
				}
				.about-values {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="about-page">
			<section class="about-hero">
				<p class="section-kicker">About AISEOShift</p>
				<h1>Covering the shift from rankings to AI visibility.</h1>
				<p>
					AISEOShift is an editorial publication focused on how search is changing. We cover AI visibility,
					answer engine optimization, generative engine optimization, citation mechanics, and the practical
					strategies teams need as AI systems increasingly mediate how people discover information.
				</p>
			</section>

			<div class="about-grid">
				<section class="about-card">
					<h2>What We Cover</h2>
					<p>
						Our coverage spans the full AI search landscape: from how Google AI Overviews select sources
						to how ChatGPT and Perplexity cite content differently. We publish strategy frameworks,
						research with real data, practical playbooks, and tool evaluations.
					</p>
					<p>
						Every article is written to be useful both for SEO practitioners adapting to AI search and
						for general audiences trying to understand how search is evolving. We avoid hype, focus on
						evidence, and publish only what we can back with data or direct analysis.
					</p>
				</section>
				<aside class="about-card">
					<h2>Coverage Areas</h2>
					<ul>
						<li>AI visibility and citation mechanics</li>
						<li>Answer Engine Optimization (AEO)</li>
						<li>Generative Engine Optimization (GEO)</li>
						<li>Google AI Overviews strategy</li>
						<li>Content structure for AI extraction</li>
						<li>SEO tools and workflow comparisons</li>
						<li>AI search trends and data</li>
					</ul>
				</aside>
			</div>

			<div class="about-values">
				<div class="value-card">
					<h3>Evidence First</h3>
					<p>Every claim is backed by data, research, or direct analysis. We cite our sources and show our reasoning.</p>
				</div>
				<div class="value-card">
					<h3>Practical Focus</h3>
					<p>Strategy without action is theory. Every article includes actionable steps teams can implement immediately.</p>
				</div>
				<div class="value-card">
					<h3>No Hype</h3>
					<p>We report what is actually changing in search, not what generates the most clicks. Direct language, honest analysis.</p>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
