---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.about-page {
				width: min(1000px, calc(100% - 2rem));
				margin: 0 auto;
				padding: 2rem 0 4rem;
			}

			.about-grid {
				display: grid;
				grid-template-columns: minmax(0, 1.4fr) minmax(260px, 0.8fr);
				gap: 1.5rem;
			}

			.about-card {
				padding: 1.75rem;
				border-radius: 1.75rem;
				border: 1px solid rgba(var(--ink), 0.1);
				background: rgba(255, 255, 255, 0.68);
			}

			.about-card h2 {
				margin-top: 0;
			}

			@media (max-width: 860px) {
				.about-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="about-page">
			<div class="about-grid">
				<section class="about-card">
					<p class="section-kicker">About AISEOShift</p>
					<h1>A publication for the part of SEO that now happens inside AI systems.</h1>
					<p>
						AISEOShift covers the shift from traditional blue-link search toward answer engines, source
						discovery, synthesis layers, and AI-mediated visibility. The editorial model is straightforward:
						report the signal, explain the mechanism, and publish practical takeaways.
					</p>
					<p>
						The site is built in Astro, stored in GitHub, and designed to be updated directly from this chat
						through repository changes. That keeps the publishing stack fast, versioned, and lightweight.
					</p>
				</section>
				<aside class="about-card">
					<h2>Coverage Areas</h2>
					<ul>
						<li>AI visibility and citation mechanics</li>
						<li>Answer Engine Optimization and GEO</li>
						<li>Programmatic SEO systems</li>
						<li>Editorial strategy and topic clusters</li>
						<li>SEO software and workflow comparisons</li>
					</ul>
				</aside>
			</div>
		</main>
		<Footer />
	</body>
</html>
