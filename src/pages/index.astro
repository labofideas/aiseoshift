---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import imageManifest from '../data/image-manifest.json';
import { SITE_DESCRIPTION, SITE_TAGLINE, SITE_TITLE } from '../consts';
import { getFeaturedPost, getLatestPosts, sortPostsByDate } from '../utils/blog';

const posts = sortPostsByDate(await getCollection('blog', ({ data }) => !data.draft));
const featured = getFeaturedPost(posts);
const latest = getLatestPosts(posts, 6).filter((post) => post.id !== featured?.id);
const topStories = posts.filter((post) => post.id !== featured?.id).slice(0, 3);
const strategy = posts.filter((post) => post.data.category === 'Strategy').slice(0, 2);
const research = posts.filter((post) => post.data.category === 'Research').slice(0, 2);
const tooling = posts.filter((post) => post.data.category === 'Tooling').slice(0, 2);
const playbooks = posts.filter((post) => post.data.category === 'Playbooks').slice(0, 2);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} | ${SITE_TAGLINE}`} description={SITE_DESCRIPTION} />
		<style>
			.front-page {
				width: min(1200px, calc(100% - 2rem));
				margin: 0 auto;
				padding: 1.5rem 0 4rem;
			}

			.hero-stage {
				display: grid;
				grid-template-columns: minmax(0, 1.7fr) minmax(320px, 0.85fr);
				gap: 1.5rem;
				margin-bottom: 2rem;
			}

			.market-bar {
				display: grid;
				grid-template-columns: repeat(4, minmax(0, 1fr));
				gap: 0.85rem;
				margin: 0 0 1rem;
			}

			.market-chip,
			.hero-story,
			.digest-panel,
			.story-card,
			.topic-panel,
			feature-strip article {
				border: 1px solid rgba(var(--ink), 0.1);
				border-radius: 2rem;
				background: var(--panel);
				box-shadow: var(--shadow-tight);
			}

			.market-chip {
				padding: 1rem 1.1rem;
			}

			.market-chip strong {
				display: block;
				font-size: 0.72rem;
				font-weight: 700;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: rgba(var(--ink), 0.54);
			}

			.market-chip span {
				display: block;
				margin-top: 0.35rem;
				font-size: 0.88rem;
				line-height: 1.58;
			}

			.hero-story {
				padding: 1.2rem;
				background:
					linear-gradient(150deg, rgba(255, 107, 44, 0.16), rgba(23, 28, 46, 0.03) 50%),
					var(--panel);
			}

			.eyebrow,
			.section-label {
				margin: 0 0 1rem;
				font-size: 0.68rem;
				font-weight: 700;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: var(--signal-deep);
			}

			.hero-story h1 {
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
				font-size: clamp(2.35rem, 5vw, 3.8rem);
				line-height: 1;
				letter-spacing: -0.035em;
				margin: 0 0 0.9rem;
				max-width: 12ch;
			}

			.hero-story p {
				max-width: 42rem;
				font-size: 0.96rem;
				line-height: 1.7;
			}

			.hero-thumb,
			.card-thumb {
				width: 100%;
				aspect-ratio: 16 / 9;
				object-fit: cover;
				border-radius: 1.4rem;
				margin-bottom: 1rem;
			}

			.hero-shell {
				display: grid;
				grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
				gap: 1.25rem;
				align-items: end;
			}

			.hero-copy {
				padding: 1rem 1rem 1.2rem;
			}

			.hero-thumb {
				height: 100%;
				margin-bottom: 0;
				min-height: 24rem;
			}

			.hero-meta,
			.card-meta {
				color: rgba(var(--ink), 0.62);
				font-size: 0.8rem;
			}

			.hero-link,
			.card-link {
				color: inherit;
				text-decoration: none;
			}

			.hero-link:hover h1,
			.card-link:hover h3 {
				color: var(--signal-deep);
			}

			.digest-panel {
				padding: 1.5rem;
				background:
					linear-gradient(180deg, rgba(23, 28, 46, 0.02), rgba(255, 255, 255, 0.75)),
					var(--panel);
			}

			.digest-panel h2 {
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
				font-size: clamp(1.35rem, 2vw, 1.85rem);
				line-height: 1.2;
				letter-spacing: -0.025em;
				margin-bottom: 0.8rem;
			}

			.digest-panel p {
				font-size: 0.9rem;
				line-height: 1.62;
			}

			.digest-panel ol {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				gap: 1rem;
			}

			.digest-panel li {
				padding-top: 1rem;
				border-top: 1px solid rgba(var(--ink), 0.08);
			}

			.digest-panel li:first-child {
				padding-top: 0;
				border-top: 0;
			}

			.stories-grid,
			.topics-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 1rem;
				margin-bottom: 2rem;
			}

			.story-card,
			.topic-panel {
				padding: 1.35rem;
			}

			.story-card h3,
			.topic-panel h3 {
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
				font-size: 1.05rem;
				line-height: 1.35;
				letter-spacing: -0.015em;
				margin-bottom: 0.75rem;
			}

			.story-card p,
			.topic-panel p {
				font-size: 0.88rem;
				line-height: 1.62;
			}

			.topic-panel ul {
				list-style: none;
				padding: 0;
				margin: 1.25rem 0 0;
			}

			.topic-panel li + li {
				margin-top: 0.85rem;
				padding-top: 0.85rem;
				border-top: 1px solid rgba(var(--ink), 0.08);
			}

			.topic-panel a {
				text-decoration: none;
				color: rgb(var(--ink));
				font-weight: 700;
			}

			.feature-strip {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1rem;
				margin: 0 0 2rem;
			}

			.feature-strip article {
				padding: 1.25rem 1.35rem;
			}

			.feature-strip h3 {
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
				font-size: 1.05rem;
				line-height: 1.35;
				letter-spacing: -0.015em;
				margin-bottom: 0.7rem;
			}

			.feature-strip p {
				font-size: 0.88rem;
				line-height: 1.62;
			}

			.page-intro {
				display: flex;
				align-items: end;
				justify-content: space-between;
				gap: 1rem;
				margin-bottom: 1rem;
			}

			.page-intro h2 {
				margin-bottom: 0;
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
				font-size: clamp(1.4rem, 2vw, 1.85rem);
				line-height: 1.18;
				letter-spacing: -0.02em;
			}

			.page-intro a {
				font-size: 0.84rem;
				font-weight: 700;
			}

			@media (max-width: 960px) {
				.market-bar,
				.hero-stage,
				.hero-shell,
				.feature-strip,
				.stories-grid,
				.topics-grid {
					grid-template-columns: 1fr;
				}

				.hero-thumb {
					min-height: 18rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="front-page">
			<section class="market-bar" aria-label="Coverage areas">
				<div class="market-chip">
					<strong>Coverage</strong>
					<span>AI visibility, AEO, GEO, citations, tooling, and scalable content systems.</span>
				</div>
				<div class="market-chip">
					<strong>Format</strong>
					<span>News-style explainers and field guides built for SEO teams adapting to AI search.</span>
				</div>
				<div class="market-chip">
					<strong>Speed</strong>
					<span>Static Astro build, fast image pipeline, GitHub publishing workflow.</span>
				</div>
				<div class="market-chip">
					<strong>Mission</strong>
					<span>Turn shifting search mechanics into practical editorial signal.</span>
				</div>
			</section>

			<section class="hero-stage">
				{
					featured && (
						<article class="hero-story">
							<div class="hero-shell">
								<div class="hero-copy">
									<p class="eyebrow">Lead Story</p>
									<a class="hero-link" href={`/blog/${featured.id}/`}>
										<h1>{featured.data.title}</h1>
										<p>{featured.data.deck}</p>
									</a>
									<p class="hero-meta">{featured.data.category} · {featured.data.author}</p>
								</div>
								{
									imageManifest[featured.id as keyof typeof imageManifest]?.hero && (
										<img
											class="hero-thumb"
											src={imageManifest[featured.id as keyof typeof imageManifest].hero.src}
											alt={imageManifest[featured.id as keyof typeof imageManifest].hero.alt}
										/>
									)
								}
							</div>
						</article>
					)
				}
				<aside class="digest-panel">
					<p class="section-label">Signals Desk</p>
					<h2>The AI search beat is moving faster than the old SEO playbook.</h2>
					<p>
						AISEOShift tracks the mechanics behind citations, answer engines, structured authority, and the
						content systems that still move traffic.
					</p>
					<ol>
						{topStories.map((post) => (
							<li>
								<a class="card-link" href={`/blog/${post.id}/`}>
									<strong>{post.data.title}</strong>
								</a>
								<div class="card-meta">{post.data.category}</div>
							</li>
						))}
					</ol>
				</aside>
			</section>

			<section class="feature-strip">
				<article>
					<p class="section-label">What Matters</p>
					<h3>Winning the answer is becoming as important as ranking the page.</h3>
					<p>
						The strongest brands are designing content for retrieval, synthesis, and attribution instead of
						stopping at keyword position.
					</p>
				</article>
				<article>
					<p class="section-label">Editorial Angle</p>
					<h3>This site is built to feel like a newsroom for AI-era organic growth.</h3>
					<p>
						Every post sits inside a broader beat: strategy, research, tooling, or playbooks.
					</p>
				</article>
			</section>

			<section>
				<div class="page-intro">
					<div>
						<p class="section-label">Top Stories</p>
						<h2>The latest coverage</h2>
					</div>
					<a href="/blog">Browse the archive</a>
				</div>
				<div class="stories-grid">
					{latest.slice(0, 3).map((post) => (
						<article class="story-card">
							<p class="eyebrow">{post.data.category}</p>
							<a class="card-link" href={`/blog/${post.id}/`}>
								{
									imageManifest[post.id as keyof typeof imageManifest]?.hero && (
										<img
											class="card-thumb"
											src={imageManifest[post.id as keyof typeof imageManifest].hero.src}
											alt={imageManifest[post.id as keyof typeof imageManifest].hero.alt}
											loading="lazy"
										/>
									)
								}
								<h3>{post.data.title}</h3>
								<p>{post.data.description}</p>
							</a>
							<div class="card-meta">{post.data.author}</div>
						</article>
					))}
				</div>
			</section>

			<section class="topics-grid" aria-label="Editorial desks">
				<section class="topic-panel">
					<p class="section-label">Strategy Desk</p>
					<h3>Frameworks for ranking in answer-first search</h3>
					<ul>
						{strategy.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>{post.data.title}</a>
								<p>{post.data.description}</p>
							</li>
						))}
					</ul>
				</section>
				<section class="topic-panel">
					<p class="section-label">Research Desk</p>
					<h3>Citations, sources, and the systems shaping trust</h3>
					<ul>
						{research.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>{post.data.title}</a>
								<p>{post.data.description}</p>
							</li>
						))}
					</ul>
				</section>
				<section class="topic-panel">
					<p class="section-label">Tooling Desk</p>
					<h3>Software and workflows worth paying attention to</h3>
					<ul>
						{tooling.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>{post.data.title}</a>
								<p>{post.data.description}</p>
							</li>
						))}
					</ul>
				</section>
			</section>

			<section class="topics-grid" aria-label="Playbook and archive highlights">
				<section class="topic-panel">
					<p class="section-label">Playbooks</p>
					<h3>Repeatable systems for sustainable growth</h3>
					<ul>
						{playbooks.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>{post.data.title}</a>
								<p>{post.data.description}</p>
							</li>
						))}
					</ul>
				</section>
				<section class="topic-panel">
					<p class="section-label">Publishing Stack</p>
					<h3>Fast by design and simple to maintain</h3>
					<ul>
						<li>
							<a href="/blog">Static delivery with Astro</a>
							<p>No WordPress overhead, no database dependency, and clean SEO markup.</p>
						</li>
						<li>
							<a href="/about">GitHub-driven updates</a>
							<p>Content, media, and layout changes all stay versioned and easy to publish.</p>
						</li>
					</ul>
				</section>
				<section class="topic-panel">
					<p class="section-label">Next Issues</p>
					<h3>The next publishing pass can go deeper</h3>
					<ul>
						<li>
							<a href="/blog">More field reports</a>
							<p>We can keep expanding this with new beats, comparison hubs, and research roundups.</p>
						</li>
						<li>
							<a href="/blog">Richer article layouts</a>
							<p>Pull quotes, comparison tables, and citation blocks can be added without changing the stack.</p>
						</li>
					</ul>
				</section>
			</section>
		</main>
		<Footer />
	</body>
</html>
