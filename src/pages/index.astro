---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TAGLINE, SITE_TITLE } from '../consts';
import { getFeaturedPost, getLatestPosts, sortPostsByDate } from '../utils/blog';

const posts = sortPostsByDate(await getCollection('blog', ({ data }) => !data.draft));
const featured = getFeaturedPost(posts);
const latest = getLatestPosts(posts, 6).filter((post) => post.id !== featured?.id);
const topStories = posts.filter((post) => post.id !== featured?.id).slice(0, 3);
const strategy = posts.filter((post) => post.data.category === 'Strategy').slice(0, 2);
const research = posts.filter((post) => post.data.category === 'Research').slice(0, 2);
const tooling = posts.filter((post) => post.data.category === 'Tooling').slice(0, 2);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} | ${SITE_TAGLINE}`} description={SITE_DESCRIPTION} />
		<style>
			.front-page {
				width: min(1200px, calc(100% - 2rem));
				margin: 0 auto;
				padding: 1.75rem 0 4rem;
			}

			.news-band {
				display: grid;
				grid-template-columns: minmax(0, 2fr) minmax(300px, 1fr);
				gap: 1.5rem;
				margin-bottom: 2rem;
			}

			.hero-story,
			.digest-panel,
			.story-card,
			.topic-panel {
				border: 1px solid rgba(var(--ink), 0.1);
				border-radius: 2rem;
				background: rgba(255, 255, 255, 0.72);
			}

			.hero-story {
				padding: 2rem;
				background:
					linear-gradient(160deg, rgba(255, 107, 44, 0.16), rgba(23, 28, 46, 0.02) 45%),
					rgba(255, 255, 255, 0.72);
			}

			.eyebrow,
			.section-label {
				margin: 0 0 1rem;
				font-size: 0.78rem;
				font-weight: 700;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: var(--signal-deep);
			}

			.hero-story h1 {
				font-size: clamp(3rem, 7vw, 6rem);
				line-height: 0.92;
				margin: 0 0 1rem;
				max-width: 12ch;
			}

			.hero-story p {
				max-width: 42rem;
				font-size: 1.15rem;
			}

			.hero-meta,
			.card-meta {
				color: rgba(var(--ink), 0.62);
				font-size: 0.92rem;
			}

			.hero-link,
			.card-link {
				color: inherit;
				text-decoration: none;
			}

			.hero-link:hover h1,
			.card-link:hover h3 {
				color: var(--signal-deep);
			}

			.digest-panel {
				padding: 1.5rem;
			}

			.digest-panel ol {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				gap: 1rem;
			}

			.digest-panel li {
				padding-top: 1rem;
				border-top: 1px solid rgba(var(--ink), 0.08);
			}

			.digest-panel li:first-child {
				padding-top: 0;
				border-top: 0;
			}

			.stories-grid,
			.topics-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 1rem;
				margin-bottom: 2rem;
			}

			.story-card,
			.topic-panel {
				padding: 1.35rem;
			}

			.story-card h3,
			.topic-panel h3 {
				font-size: 1.45rem;
				margin-bottom: 0.75rem;
			}

			.story-card p,
			.topic-panel p {
				font-size: 0.98rem;
			}

			.topic-panel ul {
				list-style: none;
				padding: 0;
				margin: 1.25rem 0 0;
			}

			.topic-panel li + li {
				margin-top: 0.85rem;
				padding-top: 0.85rem;
				border-top: 1px solid rgba(var(--ink), 0.08);
			}

			.topic-panel a {
				text-decoration: none;
				color: rgb(var(--ink));
				font-weight: 700;
			}

			.page-intro {
				display: flex;
				align-items: end;
				justify-content: space-between;
				gap: 1rem;
				margin-bottom: 1rem;
			}

			.page-intro h2 {
				margin-bottom: 0;
			}

			.page-intro a {
				font-size: 0.92rem;
				font-weight: 700;
			}

			@media (max-width: 960px) {
				.news-band,
				.stories-grid,
				.topics-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="front-page">
			<section class="news-band">
				{
					featured && (
						<article class="hero-story">
							<p class="eyebrow">Lead Story</p>
							<a class="hero-link" href={`/blog/${featured.id}/`}>
								<h1>{featured.data.title}</h1>
								<p>{featured.data.deck}</p>
							</a>
							<p class="hero-meta">{featured.data.category} · {featured.data.author}</p>
						</article>
					)
				}
				<aside class="digest-panel">
					<p class="section-label">Editor&apos;s Note</p>
					<h2>The AI search beat is moving faster than the SEO playbook.</h2>
					<p>
						AISEOShift tracks the mechanics behind citations, answer engines, structured authority, and the
						content systems that still move traffic.
					</p>
					<ol>
						{topStories.map((post) => (
							<li>
								<a class="card-link" href={`/blog/${post.id}/`}>
									<strong>{post.data.title}</strong>
								</a>
								<div class="card-meta">{post.data.category}</div>
							</li>
						))}
					</ol>
				</aside>
			</section>

			<section>
				<div class="page-intro">
					<div>
						<p class="section-label">Top Stories</p>
						<h2>The latest coverage</h2>
					</div>
					<a href="/blog">Browse the archive</a>
				</div>
				<div class="stories-grid">
					{latest.slice(0, 3).map((post) => (
						<article class="story-card">
							<p class="eyebrow">{post.data.category}</p>
							<a class="card-link" href={`/blog/${post.id}/`}>
								<h3>{post.data.title}</h3>
								<p>{post.data.description}</p>
							</a>
							<div class="card-meta">{post.data.author}</div>
						</article>
					))}
				</div>
			</section>

			<section class="topics-grid" aria-label="Editorial desks">
				<section class="topic-panel">
					<p class="section-label">Strategy Desk</p>
					<h3>Frameworks for ranking in answer-first search</h3>
					<ul>
						{strategy.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>{post.data.title}</a>
								<p>{post.data.description}</p>
							</li>
						))}
					</ul>
				</section>
				<section class="topic-panel">
					<p class="section-label">Research Desk</p>
					<h3>Citations, sources, and the systems shaping trust</h3>
					<ul>
						{research.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>{post.data.title}</a>
								<p>{post.data.description}</p>
							</li>
						))}
					</ul>
				</section>
				<section class="topic-panel">
					<p class="section-label">Tooling Desk</p>
					<h3>Software and workflows worth paying attention to</h3>
					<ul>
						{tooling.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>{post.data.title}</a>
								<p>{post.data.description}</p>
							</li>
						))}
					</ul>
				</section>
			</section>
		</main>
		<Footer />
	</body>
</html>
