---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import imageManifest from '../data/image-manifest.json';
import { SITE_DESCRIPTION, SITE_TAGLINE, SITE_TITLE, SITE_URL } from '../consts';
import { getFeaturedPost, getLatestPosts, sortPostsByDate } from '../utils/blog';

const posts = sortPostsByDate(await getCollection('blog', ({ data }) => !data.draft));
const featured = getFeaturedPost(posts);
const latest = getLatestPosts(posts, 6).filter((post) => post.id !== featured?.id);
const topStories = posts.filter((post) => post.id !== featured?.id).slice(0, 3);
const strategy = posts.filter((post) => post.data.category === 'Strategy').slice(0, 2);
const research = posts.filter((post) => post.data.category === 'Research').slice(0, 2);
const tooling = posts.filter((post) => post.data.category === 'Tooling').slice(0, 2);
const playbooks = posts.filter((post) => post.data.category === 'Playbooks').slice(0, 2);
const labNotes = [
	{
		label: 'Publishing Stack',
		title: 'Static delivery with Astro',
		description: 'Fast pages, clean markup, and a publishing workflow that stays easy to maintain.',
		href: '/blog',
	},
	{
		label: 'Workflow',
		title: 'GitHub-driven updates',
		description: 'Layout, content, and media changes all ship through versioned pushes and Cloudflare deploys.',
		href: '/about',
	},
	{
		label: 'Next Issue',
		title: 'Field reports and benchmark pages',
		description: 'The strongest next additions are prompt studies, comparison hubs, and narrow citation playbooks.',
		href: '/blog',
	},
];
const homepageStructuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: SITE_TITLE,
		url: SITE_URL,
		description: SITE_DESCRIPTION,
		inLanguage: 'en',
	},
	{
		'@context': 'https://schema.org',
		'@type': 'Organization',
		name: SITE_TITLE,
		url: SITE_URL,
		description: SITE_DESCRIPTION,
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`AI Visibility, AEO, and Answer Engine Search Strategy | ${SITE_TITLE}`}
			description={SITE_DESCRIPTION}
			structuredData={homepageStructuredData}
		/>
		<style>
			.front-page {
				width: min(1200px, calc(100% - 2rem));
				margin: 0 auto;
				padding: 1.4rem 0 4rem;
			}

			.hero-intro {
				display: grid;
				grid-template-columns: minmax(0, 1fr) auto;
				gap: 1.2rem;
				align-items: center;
				padding: 0.2rem 0 1.65rem;
				margin-bottom: 1.55rem;
				border-bottom: 1px solid rgba(var(--ink), 0.08);
			}

			.hero-intro-copy {
				max-width: 38rem;
			}

			.hero-intro-copy p {
				margin: 0;
			}

			.hero-intro-copy h1 {
				font-family: 'Iowan Old Style', 'Palatino Linotype', 'Book Antiqua', 'Georgia', serif;
				font-size: clamp(2.35rem, 4.5vw, 3.65rem);
				line-height: 0.92;
				letter-spacing: -0.045em;
				margin: 0 0 0.8rem;
				max-width: 10ch;
			}

			.hero-intro-copy strong {
				display: block;
				margin-bottom: 0.45rem;
				font-size: 0.72rem;
				letter-spacing: 0.18em;
				text-transform: uppercase;
				color: var(--signal-deep);
			}

			.hero-intro-copy p {
				font-size: 1rem;
				line-height: 1.7;
				color: rgba(var(--ink), 0.84);
			}

			.hero-intro-link {
				display: inline-flex;
				align-items: center;
				padding: 0.9rem 1.15rem;
				border: 1px solid rgba(var(--ink), 0.12);
				border-radius: 999px;
				background: rgba(255, 255, 255, 0.5);
				font-size: 0.72rem;
				font-weight: 700;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				text-decoration: none;
				color: rgb(var(--ink));
			}

			.hero-stage {
				display: grid;
				grid-template-columns: minmax(0, 1.7fr) minmax(320px, 0.85fr);
				gap: 1.4rem;
				margin-bottom: 2.2rem;
			}

			.hero-story,
			.digest-panel,
			.story-card,
			.topic-panel,
			feature-strip article {
				border: 1px solid var(--line);
				border-radius: 28px;
				background:
					linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(244, 243, 239, 0.72));
				box-shadow: 0 18px 40px rgba(23, 28, 46, 0.06);
			}

			.hero-story {
				padding: 1.1rem;
				position: relative;
				overflow: hidden;
			}

			.eyebrow,
			.section-label {
				margin: 0 0 1rem;
				font-size: 0.72rem;
				font-weight: 700;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: var(--signal-deep);
			}

			.hero-story h2 {
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
				font-size: clamp(2.1rem, 4.3vw, 3.5rem);
				line-height: 0.96;
				letter-spacing: -0.04em;
				margin: 0 0 0.9rem;
				max-width: 12ch;
			}

			.hero-story p {
				max-width: 42rem;
				font-size: 0.96rem;
				line-height: 1.7;
			}

			.hero-thumb,
			.card-thumb {
				width: 100%;
				aspect-ratio: 16 / 9;
				object-fit: cover;
				border-radius: 10px;
				margin-bottom: 1rem;
			}

			.hero-shell {
				display: grid;
				grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
				gap: 1.25rem;
				align-items: stretch;
			}

			.hero-copy {
				padding: 1.15rem 1rem 1.15rem 0.3rem;
			}

			.hero-thumb {
				height: 100%;
				margin-bottom: 0;
				min-height: 24rem;
				box-shadow: 0 18px 34px rgba(23, 28, 46, 0.18);
			}

			.hero-meta,
			.card-meta {
				color: rgba(var(--ink), 0.62);
				font-size: 0.8rem;
			}

			.hero-meta {
				display: flex;
				flex-wrap: wrap;
				gap: 0.75rem;
				margin-top: 1rem;
				padding-top: 0.85rem;
				border-top: 1px solid rgba(var(--ink), 0.08);
				text-transform: uppercase;
				letter-spacing: 0.08em;
				font-size: 0.72rem;
			}

			.hero-link,
			.card-link {
				color: inherit;
				text-decoration: none;
			}

			.hero-link:hover h2,
			.card-link:hover h3 {
				color: var(--signal-deep);
			}

			.digest-panel {
				padding: 1.5rem 1.45rem;
				background:
					linear-gradient(180deg, rgba(255, 255, 255, 0.84), rgba(249, 246, 241, 0.94));
			}

			.digest-panel h2 {
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
				font-size: clamp(1.35rem, 2vw, 1.85rem);
				line-height: 1.2;
				letter-spacing: -0.025em;
				margin-bottom: 0.8rem;
			}

			.digest-panel p {
				font-size: 0.9rem;
				line-height: 1.62;
			}

			.digest-panel ol {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				gap: 1rem;
			}

			.digest-panel li {
				padding-top: 1rem;
				border-top: 1px solid rgba(var(--ink), 0.08);
			}

			.digest-panel li:first-child {
				padding-top: 0;
				border-top: 0;
			}

			.stories-grid,
			.topics-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 1rem;
				margin-bottom: 2rem;
			}

			.desks-layout {
				display: grid;
				grid-template-columns: minmax(0, 1.45fr) minmax(320px, 0.85fr);
				gap: 1rem;
				margin-bottom: 2rem;
			}

			.desks-stack {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1rem;
			}

			.story-card,
			.topic-panel {
				padding: 1.35rem 1.3rem 1.4rem;
				background:
					linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(250, 249, 246, 0.74));
			}

			.story-card h3,
			.topic-panel h3 {
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
				font-size: 1.05rem;
				line-height: 1.35;
				letter-spacing: -0.015em;
				margin-bottom: 0.75rem;
			}

			.story-card p,
			.topic-panel p {
				font-size: 0.88rem;
				line-height: 1.62;
			}

			.topic-panel ul {
				list-style: none;
				padding: 0;
				margin: 0.95rem 0 0;
			}

			.topic-panel {
				padding-top: 1.35rem;
			}

			.topic-panel li + li {
				margin-top: 0.85rem;
				padding-top: 0.85rem;
				border-top: 1px solid rgba(var(--ink), 0.08);
			}

			.topic-panel a {
				text-decoration: none;
				color: rgb(var(--ink));
				font-weight: 700;
			}

			.topic-panel.lead-desk {
				background:
					linear-gradient(180deg, rgba(217, 106, 58, 0.1), rgba(255, 255, 255, 0.84));
			}

			.lab-panel {
				display: grid;
				grid-template-rows: auto auto 1fr;
				gap: 1.2rem;
				padding: 1.45rem;
				border: 1px solid rgba(var(--ink), 0.1);
				border-radius: 32px;
				background:
					linear-gradient(155deg, rgba(23, 28, 46, 0.94), rgba(58, 45, 41, 0.92));
				color: rgb(var(--paper));
				box-shadow: 0 22px 44px rgba(23, 28, 46, 0.18);
			}

			.lab-panel .section-label,
			.lab-panel a,
			.lab-panel h2,
			.lab-panel strong {
				color: inherit;
			}

			.lab-panel h2 {
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
				font-size: clamp(1.6rem, 2.6vw, 2.25rem);
				line-height: 1.05;
				letter-spacing: -0.03em;
				margin: 0;
				max-width: 11ch;
			}

			.lab-panel p {
				margin: 0;
				color: rgba(250, 249, 246, 0.78);
				font-size: 0.92rem;
				line-height: 1.65;
			}

			.lab-notes {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				gap: 1rem;
			}

			.lab-notes li {
				padding-top: 1rem;
				border-top: 1px solid rgba(250, 249, 246, 0.14);
			}

			.lab-notes li:first-child {
				padding-top: 0;
				border-top: 0;
			}

			.lab-notes span {
				display: block;
				margin-bottom: 0.35rem;
				font-size: 0.68rem;
				font-weight: 700;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: rgba(250, 249, 246, 0.58);
			}

			.lab-notes a {
				text-decoration: none;
				font-weight: 700;
			}

			.feature-strip {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1rem;
				margin: 0 0 2rem;
			}

			.feature-strip article {
				padding: 1.35rem 1.3rem;
			}

			.feature-strip article:first-child {
				background:
					linear-gradient(180deg, rgba(217, 106, 58, 0.18), rgba(255, 255, 255, 0.78));
			}

			.feature-strip article:last-child {
				background:
					linear-gradient(180deg, rgba(23, 28, 46, 0.04), rgba(255, 255, 255, 0.78));
			}

			.feature-strip p {
				font-size: 0.88rem;
				line-height: 1.62;
			}

			.page-intro {
				display: flex;
				align-items: end;
				justify-content: space-between;
				gap: 1rem;
				margin-bottom: 1.15rem;
			}

			.page-intro h2 {
				margin-bottom: 0;
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
				font-size: clamp(1.4rem, 2vw, 1.85rem);
				line-height: 1.18;
				letter-spacing: -0.02em;
			}

			.page-intro a {
				font-size: 0.72rem;
				font-weight: 700;
				letter-spacing: 0.14em;
				text-transform: uppercase;
			}

			@media (max-width: 960px) {
				.hero-stage,
				.hero-shell,
				.feature-strip,
				.desks-layout,
				.desks-stack,
				.stories-grid,
				.topics-grid {
					grid-template-columns: 1fr;
				}

				.hero-thumb {
					min-height: 18rem;
				}

				.digest-panel {
					padding: 1.2rem;
				}

				.feature-strip article:last-child {
					padding-left: 1.3rem;
				}

				.lab-panel h2 {
					max-width: none;
				}
			}

			@media (max-width: 720px) {
				.hero-intro {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="front-page">
			<section class="hero-intro" aria-label="Site introduction">
				<div class="hero-intro-copy">
					<strong>Signals for the AI search transition</strong>
					<h1>AI visibility, AEO, and answer engine search strategy.</h1>
					<p>
						AISEOShift covers citations, answer engines, retrieval patterns, and the editorial systems SEO
						teams need now that classic blue-link ranking is no longer the whole game.
					</p>
				</div>
				<a class="hero-intro-link" href="/blog">View all coverage</a>
			</section>

			<section class="hero-stage">
				{
					featured && (
						<article class="hero-story">
							<div class="hero-shell">
								<div class="hero-copy">
									<p class="eyebrow">Lead Story</p>
									<a class="hero-link" href={`/blog/${featured.id}/`}>
										<h2>{featured.data.title}</h2>
										<p>{featured.data.deck}</p>
									</a>
									<p class="hero-meta">
										<span>{featured.data.category}</span>
										<span>{featured.data.author}</span>
									</p>
								</div>
								{
									imageManifest[featured.id as keyof typeof imageManifest]?.hero && (
										<img
											class="hero-thumb"
											src={imageManifest[featured.id as keyof typeof imageManifest].hero.src}
											alt={imageManifest[featured.id as keyof typeof imageManifest].hero.alt}
										/>
									)
								}
							</div>
						</article>
					)
				}
				<aside class="digest-panel">
					<p class="section-label">Signals Desk</p>
					<h2>The AI search beat is moving faster than the old SEO playbook.</h2>
					<p>
						AISEOShift tracks the mechanics behind citations, answer engines, structured authority, and the
						content systems that still move traffic.
					</p>
					<ol>
						{topStories.map((post) => (
							<li>
								<a class="card-link" href={`/blog/${post.id}/`}>
									<strong>{post.data.title}</strong>
								</a>
								<div class="card-meta">{post.data.category}</div>
							</li>
						))}
					</ol>
				</aside>
			</section>

			<section class="feature-strip">
				<article>
					<p class="section-label">What Matters</p>
					<p>
						The strongest brands are designing content for retrieval, synthesis, and attribution instead of
						stopping at keyword position.
					</p>
				</article>
				<article>
					<p class="section-label">Editorial Angle</p>
					<p>
						Every story lives inside a desk, so readers can move from the lead story into strategy, research,
						tooling, or repeatable playbooks without hitting visual filler first.
					</p>
				</article>
			</section>

			<section>
				<div class="page-intro">
					<div>
						<p class="section-label">Top Stories</p>
						<h2>The latest coverage</h2>
					</div>
					<a href="/blog">Browse the archive</a>
				</div>
				<div class="stories-grid">
					{latest.slice(0, 3).map((post) => (
						<article class="story-card">
							<p class="eyebrow">{post.data.category}</p>
							<a class="card-link" href={`/blog/${post.id}/`}>
								{
									imageManifest[post.id as keyof typeof imageManifest]?.hero && (
										<img
											class="card-thumb"
											src={imageManifest[post.id as keyof typeof imageManifest].hero.src}
											alt={imageManifest[post.id as keyof typeof imageManifest].hero.alt}
											loading="lazy"
										/>
									)
								}
								<h3>{post.data.title}</h3>
								<p>{post.data.description}</p>
							</a>
							<div class="card-meta">{post.data.author}</div>
						</article>
					))}
				</div>
			</section>

			<section class="desks-layout" aria-label="Editorial desks">
				<div class="desks-stack">
					<section class="topic-panel lead-desk">
					<p class="section-label">Strategy Desk</p>
					<ul>
						{strategy.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>{post.data.title}</a>
								<p>{post.data.description}</p>
							</li>
						))}
					</ul>
					</section>
					<section class="topic-panel">
					<p class="section-label">Research Desk</p>
					<ul>
						{research.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>{post.data.title}</a>
								<p>{post.data.description}</p>
							</li>
						))}
					</ul>
					</section>
					<section class="topic-panel">
					<p class="section-label">Tooling Desk</p>
					<ul>
						{tooling.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>{post.data.title}</a>
								<p>{post.data.description}</p>
							</li>
						))}
					</ul>
					</section>
					<section class="topic-panel">
						<p class="section-label">Playbooks</p>
						<ul>
							{playbooks.map((post) => (
								<li>
									<a href={`/blog/${post.id}/`}>{post.data.title}</a>
									<p>{post.data.description}</p>
								</li>
							))}
						</ul>
					</section>
				</div>
				<aside class="lab-panel">
					<div>
						<p class="section-label">Editor&apos;s Note</p>
						<h2>The publication should feel like a working desk, not a generic blog grid.</h2>
					</div>
					<p>
						AISEOShift is strongest when it behaves like a narrow operating manual for the answer-engine era:
						clear definitions, citation logic, retrieval strategy, and practical playbooks that teams can use.
					</p>
					<ul class="lab-notes">
						{labNotes.map((item) => (
							<li>
								<span>{item.label}</span>
								<a href={item.href}>{item.title}</a>
								<p>{item.description}</p>
							</li>
						))}
					</ul>
				</aside>
			</section>
		</main>
		<Footer />
	</body>
</html>
