---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import imageManifest from '../data/image-manifest.json';
import { SITE_DESCRIPTION, SITE_TAGLINE, SITE_TITLE, SITE_URL } from '../consts';
import { getFeaturedPost, getLatestPosts, sortPostsByDate } from '../utils/blog';

const posts = sortPostsByDate(await getCollection('blog', ({ data }) => !data.draft));
const featured = getFeaturedPost(posts);
const latest = getLatestPosts(posts, 9).filter((post) => post.id !== featured?.id);
const topStories = posts.filter((post) => post.id !== featured?.id).slice(0, 3);
const strategy = posts.filter((post) => post.data.category === 'Strategy').slice(0, 3);
const research = posts.filter((post) => post.data.category === 'Research').slice(0, 3);
const tooling = posts.filter((post) => post.data.category === 'Tooling').slice(0, 3);
const playbooks = posts.filter((post) => post.data.category === 'Playbooks').slice(0, 3);
const homepageStructuredData = [
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: SITE_TITLE,
		url: SITE_URL,
		description: SITE_DESCRIPTION,
		inLanguage: 'en',
	},
	{
		'@context': 'https://schema.org',
		'@type': 'Organization',
		name: SITE_TITLE,
		url: SITE_URL,
		description: SITE_DESCRIPTION,
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`AI Visibility, AEO, and Answer Engine Search Strategy | ${SITE_TITLE}`}
			description={SITE_DESCRIPTION}
			structuredData={homepageStructuredData}
		/>
		<style>
			.front-page {
				width: min(1200px, calc(100% - 2rem));
				margin: 0 auto;
				padding: 1.4rem 0 4rem;
			}

			/* ── Hero ── */
			.hero-intro {
				display: grid;
				grid-template-columns: 1.1fr 0.9fr;
				gap: 2.5rem;
				align-items: center;
				padding: 2.5rem 0 2.5rem;
				margin-bottom: 2rem;
				border-bottom: 1px solid rgba(var(--ink), 0.08);
			}

			.hero-intro-copy h1 {
				font-family: 'Iowan Old Style', 'Palatino Linotype', 'Book Antiqua', 'Georgia', serif;
				font-size: clamp(2rem, 3.5vw, 3rem);
				line-height: 1.08;
				letter-spacing: -0.03em;
				margin: 0 0 1rem;
			}

			.hero-intro-copy p {
				margin: 0;
				font-size: 1.02rem;
				line-height: 1.72;
				color: rgba(var(--ink), 0.82);
				max-width: 34rem;
			}

			.hero-intro-link {
				display: inline-flex;
				align-items: center;
				margin-top: 1.4rem;
				padding: 0.85rem 1.3rem;
				border: 1px solid rgba(var(--ink), 0.14);
				border-radius: 999px;
				background: rgba(var(--paper-strong), 0.6);
				font-size: 0.74rem;
				font-weight: 700;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				text-decoration: none;
				color: rgb(var(--ink));
				transition: background 0.2s;
			}

			.hero-intro-link:hover {
				background: rgba(var(--paper-strong), 0.95);
			}

			.hero-intro-visual {
				display: block;
				text-decoration: none;
				border-radius: 18px;
				overflow: hidden;
			}

			.hero-intro-img {
				width: 100%;
				aspect-ratio: 16 / 10;
				object-fit: cover;
				display: block;
				border-radius: 18px;
				transition: transform 0.3s ease;
			}

			.hero-intro-visual:hover .hero-intro-img {
				transform: scale(1.02);
			}

			.hero-intro-img-caption {
				display: block;
				margin-top: 0.55rem;
				font-size: 0.78rem;
				font-weight: 600;
				color: rgba(var(--ink), 0.6);
				line-height: 1.4;
			}

			/* ── Shared ── */
			.eyebrow,
			.section-label {
				margin: 0 0 0.8rem;
				font-size: 0.72rem;
				font-weight: 700;
				letter-spacing: 0.16em;
				text-transform: uppercase;
				color: var(--signal-deep);
			}

			.page-intro {
				display: flex;
				align-items: end;
				justify-content: space-between;
				gap: 1rem;
				margin-bottom: 1.15rem;
			}

			.page-intro h2 {
				margin-bottom: 0;
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
				font-size: clamp(1.35rem, 2vw, 1.75rem);
				line-height: 1.18;
				letter-spacing: -0.02em;
			}

			.page-intro a {
				font-size: 0.72rem;
				font-weight: 700;
				letter-spacing: 0.14em;
				text-transform: uppercase;
			}

			/* ── Lead Story + Signals ── */
			.hero-stage {
				display: grid;
				grid-template-columns: minmax(0, 1.6fr) minmax(300px, 0.85fr);
				gap: 1.4rem;
				margin-bottom: 2.5rem;
			}

			.hero-story,
			.digest-panel,
			.story-card,
			.topic-panel {
				border: 1px solid var(--line);
				border-radius: 24px;
				background: rgba(var(--paper-strong), 0.55);
				box-shadow: 0 12px 30px rgba(var(--ink), 0.05);
			}

			.hero-story {
				padding: 1.1rem;
				overflow: hidden;
			}

			.hero-shell {
				display: grid;
				grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
				gap: 1.25rem;
				align-items: stretch;
			}

			.hero-copy {
				padding: 1rem 1rem 1rem 0.3rem;
			}

			.hero-story h2 {
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
				font-size: clamp(1.8rem, 3.5vw, 2.8rem);
				line-height: 1;
				letter-spacing: -0.035em;
				margin: 0 0 0.8rem;
			}

			.hero-story p {
				max-width: 42rem;
				font-size: 0.94rem;
				line-height: 1.68;
			}

			.hero-thumb {
				width: 100%;
				height: 100%;
				min-height: 20rem;
				object-fit: cover;
				border-radius: 14px;
				box-shadow: 0 14px 28px rgba(var(--ink), 0.14);
			}

			.hero-meta {
				display: flex;
				flex-wrap: wrap;
				gap: 0.75rem;
				margin-top: 0.8rem;
				padding-top: 0.75rem;
				border-top: 1px solid rgba(var(--ink), 0.08);
				text-transform: uppercase;
				letter-spacing: 0.08em;
				font-size: 0.72rem;
				color: rgba(var(--ink), 0.6);
			}

			.hero-link,
			.card-link {
				color: inherit;
				text-decoration: none;
			}

			.hero-link:hover h2,
			.card-link:hover h3 {
				color: var(--signal-deep);
			}

			/* ── Signals Desk ── */
			.digest-panel {
				padding: 1.4rem 1.35rem;
				background: rgba(var(--paper-strong), 0.7);
			}

			.digest-panel h2 {
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
				font-size: clamp(1.2rem, 1.8vw, 1.6rem);
				line-height: 1.22;
				letter-spacing: -0.02em;
				margin-bottom: 0.7rem;
			}

			.digest-panel p {
				font-size: 0.88rem;
				line-height: 1.62;
			}

			.digest-panel ol {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				gap: 0.9rem;
			}

			.digest-panel li {
				padding-top: 0.9rem;
				border-top: 1px solid rgba(var(--ink), 0.08);
			}

			.digest-panel li:first-child {
				padding-top: 0;
				border-top: 0;
			}

			.card-meta {
				color: rgba(var(--ink), 0.55);
				font-size: 0.78rem;
			}

			/* ── Stories Grid ── */
			.stories-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 1rem;
				margin-bottom: 2.5rem;
			}

			.story-card {
				padding: 1.25rem 1.2rem 1.3rem;
			}

			.card-thumb {
				width: 100%;
				aspect-ratio: 16 / 9;
				object-fit: cover;
				border-radius: 10px;
				margin-bottom: 0.9rem;
			}

			.story-card h3 {
				font-family: 'Atkinson', 'Trebuchet MS', sans-serif;
				font-size: 1.02rem;
				line-height: 1.32;
				letter-spacing: -0.01em;
				margin-bottom: 0.6rem;
			}

			.story-card p {
				font-size: 0.86rem;
				line-height: 1.6;
				color: rgba(var(--ink), 0.78);
			}

			/* ── Topics Grid ── */
			.topics-grid {
				display: grid;
				grid-template-columns: repeat(4, minmax(0, 1fr));
				gap: 1rem;
				margin-bottom: 2.5rem;
			}

			.topic-panel {
				padding: 1.25rem 1.2rem 1.3rem;
			}

			.topic-panel ul {
				list-style: none;
				padding: 0;
				margin: 0.8rem 0 0;
			}

			.topic-panel li + li {
				margin-top: 0.75rem;
				padding-top: 0.75rem;
				border-top: 1px solid rgba(var(--ink), 0.08);
			}

			.topic-panel a {
				text-decoration: none;
				color: rgb(var(--ink));
				font-weight: 700;
				font-size: 0.92rem;
				line-height: 1.35;
			}

			.topic-panel a:hover {
				color: var(--signal-deep);
			}

			.topic-panel p {
				font-size: 0.82rem;
				line-height: 1.55;
				color: rgba(var(--ink), 0.68);
				margin-top: 0.25rem;
			}

			.topic-panel.lead-desk {
				background: linear-gradient(180deg, rgba(232, 131, 79, 0.1), rgba(var(--paper-strong), 0.7));
			}

			/* ── Responsive ── */
			@media (max-width: 960px) {
				.hero-intro,
				.hero-stage,
				.hero-shell,
				.stories-grid {
					grid-template-columns: 1fr;
				}

				.topics-grid {
					grid-template-columns: repeat(2, minmax(0, 1fr));
				}

				.hero-thumb {
					min-height: 16rem;
				}

				.digest-panel {
					padding: 1.2rem;
				}
			}

			@media (max-width: 600px) {
				.topics-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="front-page">
			<section class="hero-intro" aria-label="Site introduction">
				<div class="hero-intro-copy">
					<h1>AI visibility, AEO, and answer engine search strategy.</h1>
					<p>
						AISEOShift covers citations, answer engines, retrieval patterns, and the editorial systems SEO
						teams need now that classic blue-link ranking is no longer the whole game.
					</p>
					<a class="hero-intro-link" href="/blog">Browse all articles</a>
				</div>
				{featured && imageManifest[featured.id as keyof typeof imageManifest]?.hero && (
					<a class="hero-intro-visual" href={`/blog/${featured.id}/`}>
						<img
							src={imageManifest[featured.id as keyof typeof imageManifest].hero.src}
							alt={imageManifest[featured.id as keyof typeof imageManifest].hero.alt}
							class="hero-intro-img"
						/>
						<span class="hero-intro-img-caption">Featured: {featured.data.title}</span>
					</a>
				)}
			</section>

			<section class="hero-stage">
				{featured && (
					<article class="hero-story">
						<div class="hero-shell">
							<div class="hero-copy">
								<p class="eyebrow">Lead Story</p>
								<a class="hero-link" href={`/blog/${featured.id}/`}>
									<h2>{featured.data.title}</h2>
									<p>{featured.data.deck}</p>
								</a>
								<p class="hero-meta">
									<span>{featured.data.category}</span>
									<span>{featured.data.author}</span>
								</p>
							</div>
							{imageManifest[featured.id as keyof typeof imageManifest]?.hero && (
								<img
									class="hero-thumb"
									src={imageManifest[featured.id as keyof typeof imageManifest].hero.src}
									alt={imageManifest[featured.id as keyof typeof imageManifest].hero.alt}
								/>
							)}
						</div>
					</article>
				)}
				<aside class="digest-panel">
					<p class="section-label">Trending</p>
					<h2>Recent coverage across AI search, SEO, and visibility.</h2>
					<ol>
						{topStories.map((post) => (
							<li>
								<a class="card-link" href={`/blog/${post.id}/`}>
									<strong>{post.data.title}</strong>
								</a>
								<div class="card-meta">{post.data.category}</div>
							</li>
						))}
					</ol>
				</aside>
			</section>

			<section>
				<div class="page-intro">
					<div>
						<p class="section-label">Latest</p>
						<h2>Recent articles</h2>
					</div>
					<a href="/blog">View all</a>
				</div>
				<div class="stories-grid">
					{latest.slice(0, 6).map((post) => (
						<article class="story-card">
							<p class="eyebrow">{post.data.category}</p>
							<a class="card-link" href={`/blog/${post.id}/`}>
								{imageManifest[post.id as keyof typeof imageManifest]?.hero && (
									<img
										class="card-thumb"
										src={imageManifest[post.id as keyof typeof imageManifest].hero.src}
										alt={imageManifest[post.id as keyof typeof imageManifest].hero.alt}
										loading="lazy"
									/>
								)}
								<h3>{post.data.title}</h3>
								<p>{post.data.description}</p>
							</a>
						</article>
					))}
				</div>
			</section>

			<section aria-label="Browse by topic">
				<div class="page-intro">
					<div>
						<p class="section-label">Topics</p>
						<h2>Browse by category</h2>
					</div>
				</div>
				<div class="topics-grid">
					<section class="topic-panel lead-desk">
						<p class="section-label">Strategy</p>
						<ul>
							{strategy.map((post) => (
								<li>
									<a href={`/blog/${post.id}/`}>{post.data.title}</a>
								</li>
							))}
						</ul>
					</section>
					<section class="topic-panel">
						<p class="section-label">Research</p>
						<ul>
							{research.map((post) => (
								<li>
									<a href={`/blog/${post.id}/`}>{post.data.title}</a>
								</li>
							))}
						</ul>
					</section>
					<section class="topic-panel">
						<p class="section-label">Tooling</p>
						<ul>
							{tooling.map((post) => (
								<li>
									<a href={`/blog/${post.id}/`}>{post.data.title}</a>
								</li>
							))}
						</ul>
					</section>
					<section class="topic-panel">
						<p class="section-label">Playbooks</p>
						<ul>
							{playbooks.map((post) => (
								<li>
									<a href={`/blog/${post.id}/`}>{post.data.title}</a>
								</li>
							))}
						</ul>
					</section>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
