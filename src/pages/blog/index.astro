---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { sortPostsByDate } from '../../utils/blog';

const posts = sortPostsByDate(await getCollection('blog', ({ data }) => !data.draft));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Latest Coverage | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			.archive {
				width: min(1200px, calc(100% - 2rem));
				margin: 0 auto;
				padding: 2rem 0 4rem;
			}

			.archive-header {
				margin-bottom: 2rem;
				max-width: 48rem;
			}

			.archive-grid {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}

			.archive-card {
				padding: 1.5rem;
				border: 1px solid rgba(var(--ink), 0.1);
				border-radius: 1.75rem;
				background: rgba(255, 255, 255, 0.68);
			}

			.archive-card a {
				text-decoration: none;
				color: inherit;
			}

			.archive-card h2 {
				font-size: 1.8rem;
				margin-bottom: 0.75rem;
			}

			.archive-card p {
				margin-bottom: 0.75rem;
			}

			.meta {
				color: rgba(var(--ink), 0.68);
				font-size: 0.95rem;
			}

			.category {
				font-size: 0.78rem;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				font-weight: 700;
				color: var(--signal-deep);
			}

			@media (max-width: 900px) {
				.archive-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="archive">
			<header class="archive-header">
				<p class="category">Archive</p>
				<h1>Latest coverage on AI visibility and answer-first search.</h1>
				<p>
					Reporting, explainers, and field guides covering AEO, GEO, citations, tools, and the content
					systems behind durable organic growth.
				</p>
			</header>
			<section>
				<ul class="archive-grid">
					{
						posts.map((post) => (
							<li class="archive-card">
								<a href={`/blog/${post.id}/`}>
									<p class="category">{post.data.category}</p>
									<h2>{post.data.title}</h2>
									<p>{post.data.deck}</p>
									<div class="meta">
										<FormattedDate date={post.data.pubDate} /> · {post.data.author}
									</div>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
