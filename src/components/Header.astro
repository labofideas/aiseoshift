---
import { SITE_TAGLINE, SITE_TITLE } from '../consts';
---

<header class="site-header">
	<div class="header-wrap">
		<a class="brand" href="/">
			<span class="brand-copy">
				<span class="brand-kicker">AI Search Publication</span>
				<span class="brand-title">{SITE_TITLE}</span>
				<span class="brand-tagline">Tracking citations, answer engines, and authority systems.</span>
			</span>
		</a>
		<nav aria-label="Primary">
			<a href="/">Front Page</a>
			<a href="/blog">Latest</a>
			<a href="/about">About</a>
		</nav>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		backdrop-filter: blur(14px);
		background: rgba(248, 244, 236, 0.94);
		border-bottom: 1px solid rgba(26, 32, 44, 0.08);
	}

	.header-wrap {
		width: min(1200px, calc(100% - 2rem));
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
		padding: 1rem 0;
	}

	.brand {
		text-decoration: none;
		color: rgb(var(--ink));
	}

	.brand-copy {
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
		max-width: 32rem;
	}

	.brand-kicker {
		font-size: 0.62rem;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--signal-deep);
	}

	.brand-title {
		font-family: 'Iowan Old Style', 'Palatino Linotype', 'Book Antiqua', 'Georgia', serif;
		font-size: clamp(1.45rem, 1.6vw, 1.9rem);
		font-weight: 700;
		line-height: 0.98;
		letter-spacing: 0.01em;
	}

	.brand-tagline {
		font-size: 0.72rem;
		color: rgba(var(--ink), 0.7);
		max-width: 28rem;
	}

	nav a {
		padding: 0.35rem 0;
		margin-left: 1.25rem;
		color: rgba(var(--ink), 0.82);
		text-decoration: none;
		font-size: 0.74rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		border-bottom: 2px solid transparent;
	}

	nav a:hover,
	nav a:focus-visible {
		border-bottom-color: var(--signal);
		color: rgb(var(--ink));
	}

	@media (max-width: 860px) {
		.header-wrap {
			flex-direction: column;
			align-items: flex-start;
		}

		nav a {
			margin-left: 0;
			margin-right: 1rem;
		}
	}

	@media (max-width: 640px) {
		.brand-tagline {
			max-width: none;
		}
	}
</style>
