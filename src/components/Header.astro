---
import { SITE_TAGLINE, SITE_TITLE } from '../consts';
---

<header class="site-header">
	<div class="header-wrap">
		<a class="brand" href="/">
			<span class="brand-kicker">AI Search Publication</span>
			<span class="brand-title">{SITE_TITLE}</span>
		</a>
		<div class="header-meta">
			<p class="header-note">{SITE_TAGLINE}</p>
			<nav aria-label="Primary">
				<a href="/">Front Page</a>
				<a href="/blog">Latest</a>
				<a href="/about">About</a>
			</nav>
		</div>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 20;
		backdrop-filter: blur(10px);
		background: rgba(250, 249, 246, 0.92);
		border-bottom: 1px solid var(--line);
	}

	.header-wrap {
		width: min(1200px, calc(100% - 2rem));
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem 1.5rem;
		padding: 0.7rem 0;
	}

	.brand {
		display: inline-flex;
		flex-direction: column;
		gap: 0.08rem;
		text-decoration: none;
		color: rgb(var(--ink));
	}

	.header-meta {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.45rem;
	}

	.brand-kicker {
		font-size: 0.58rem;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--signal-deep);
	}

	.brand-title {
		font-family: 'Iowan Old Style', 'Palatino Linotype', 'Book Antiqua', 'Georgia', serif;
		font-size: clamp(1.3rem, 1.5vw, 1.7rem);
		font-weight: 700;
		line-height: 0.98;
		letter-spacing: 0.01em;
	}

	.header-note {
		margin: 0;
		max-width: 30rem;
		font-size: 0.68rem;
		line-height: 1.4;
		letter-spacing: 0.02em;
		text-align: right;
		color: rgba(var(--ink), 0.62);
	}

	nav a {
		padding: 0.35rem 0;
		margin-left: 1.25rem;
		color: rgba(var(--ink), 0.82);
		text-decoration: none;
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		border-bottom: 1px solid transparent;
	}

	nav a:hover,
	nav a:focus-visible {
		border-bottom-color: var(--signal);
		color: rgb(var(--ink));
	}

	@media (max-width: 860px) {
		.header-wrap {
			flex-direction: column;
			align-items: flex-start;
		}

		.header-meta {
			align-items: flex-start;
			width: 100%;
			padding-top: 0.45rem;
			border-top: 1px solid rgba(var(--ink), 0.08);
		}

		.header-note {
			text-align: left;
		}

		nav a {
			margin-left: 0;
			margin-right: 1rem;
		}
	}

	@media (max-width: 640px) {
		.header-note {
			display: none;
		}
	}
</style>
