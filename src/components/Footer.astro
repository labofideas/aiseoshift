---
const today = new Date();
---

<footer class="site-footer">
	<div class="footer-wrap">
		<p class="footer-mark">AISEOShift</p>
		<p class="footer-copy">
			Reporting on how search, AI answers, and authority systems are changing in real time.
		</p>
		<div class="footer-links">
			<a href="/blog">Latest coverage</a>
			<a href="/about">About the publication</a>
		</div>
		<p class="footer-meta">&copy; {today.getFullYear()} AISEOShift. Built with Astro and published through GitHub.</p>
	</div>
</footer>

<style>
	.site-footer {
		padding: 4rem 0 5rem;
		border-top: 1px solid rgba(var(--ink), 0.08);
		background:
			linear-gradient(180deg, rgba(255, 255, 255, 0), rgba(23, 28, 46, 0.04)),
			rgb(var(--paper));
	}

	.footer-wrap {
		width: min(1200px, calc(100% - 2rem));
		margin: 0 auto;
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) minmax(220px, 0.8fr);
		gap: 2rem;
	}

	.footer-mark {
		margin: 0;
		font-family: 'Georgia', 'Times New Roman', serif;
		font-size: 1.75rem;
	}

	.footer-copy,
	.footer-meta {
		max-width: 42rem;
		color: rgba(var(--ink), 0.72);
	}

	.footer-links {
		display: flex;
		gap: 1.25rem;
		margin: 1.5rem 0;
		flex-wrap: wrap;
	}

	.footer-links a {
		text-decoration: none;
		color: rgb(var(--ink));
		font-weight: 700;
	}

	.footer-links a:hover,
	.footer-links a:focus-visible {
		color: var(--signal);
	}

	@media (max-width: 800px) {
		.footer-wrap {
			grid-template-columns: 1fr;
		}
	}
</style>
